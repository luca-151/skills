# Copy to .env and fill in. BOTH keys are OPTIONAL.
#
# The core of this skill — web research + writing the brand-context pack —
# needs NO API keys; it runs on the agent's own web tools. Keys are only
# needed if you opt into generating brand-anchored imagery in the (optional)
# image step.

# FAL — only needed for render_product_shot.py (nano-banana image generation).
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=

# ElevenLabs — only needed if you extract an audio bed from an existing ad as a
# tone reference. Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
