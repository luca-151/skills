{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://athina.ai/schemas/skill-meta.schema.json",
  "type": "object",
  "required": ["slug", "category", "tags", "installation"],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "category": { "type": "string", "enum": ["capabilities", "composites", "playbooks"] },
    "domain": {
      "type": "string",
      "enum": ["ads", "brand", "competitive-intel", "content", "design", "lead-generation", "monitoring", "outreach", "research", "research-tools", "sales", "seo", "social"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "enum": ["All", "ads", "brand", "competitive-intel", "content", "design", "lead-generation", "monitoring", "outreach", "research", "research-tools", "sales", "seo", "social"] },
      "uniqueItems": true
    },
    "installation": {
      "type": "object",
      "required": ["base_command", "supports"],
      "properties": {
        "base_command": { "type": "string", "minLength": 1 },
        "supports": {
          "type": "array",
          "items": { "type": "string", "enum": ["claude", "cursor", "codex"] },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "features": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "github_url": { "type": "string" },
    "author": { "type": "string" },
    "example_prompt": { "type": "string" },
    "requires_skills": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "requires_tools": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "additionalProperties": true
}
